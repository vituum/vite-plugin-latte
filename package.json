{
  "name": "@vituum/vite-plugin-latte",
  "version": "2.0.2",
  "type": "module",
  "main": "index.js",
  "types": "types/index.d.ts",
  "description": "Vite plugin for Latte, transforms latte templates via php into HTML",
  "keywords": [
    "latte",
    "vituum",
    "vite",
    "vite-plugin"
  ],
  "scripts": {
    "lint": "npm run eslint && npm run tsc",
    "tsc": "tsc",
    "eslint": "eslint '**/*.js'",
    "eslint-fix": "eslint '**/*.js' --fix",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "publish-next": "npm publish --tag next"
  },
  "dependencies": {
    "picomatch": "^4.0",
    "tinyglobby": "^0.2",
    "vituum": "^2.0"
  },
  "peerDependencies": {
    "vite": "^8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0",
    "@stylistic/eslint-plugin": "^5.10",
    "@types/node": "^25",
    "@types/picomatch": "^4.0",
    "eslint": "^10.0",
    "globals": "^17.4",
    "typescript": "^5.9"
  },
  "files": [
    "index.js",
    "handler.js",
    "handler-single.js",
    "index.php",
    "latte",
    "vendor",
    "types"
  ],
  "exports": {
    ".": {
      "default": "./index.js",
      "types": "./types/index.d.ts"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lubomirblazekcz/vite-plugin-latte.git"
  }
